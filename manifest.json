{
  "manifest_version": 3,
  "name": "MIT 课程学习侧边栏",
  "version": "0.1.0",
  "description": "把 YouTube 课程视频整理成中文大纲并保存到本地资料库。",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:45873/*",
    "http://localhost:45873/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/transcript-utils-content.js",
        "src/content.js"
      ],
      "css": [
        "src/sidebar.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MIT 课程学习侧边栏",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_popup": "src/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/panel.html",
        "src/page-bridge.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
